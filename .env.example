# ============================================================
# BonusByte Hub 2.0 — Environment Variables Template
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to version control
# ============================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

VITE_FIREBASE_API_KEY=your_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# The hidden admin gateway — choose a non-obvious path
VITE_ADMIN_ROUTE=/your-secret-admin-path

VITE_MAX_CPS=20
VITE_MAX_ENERGY=1000
VITE_REGEN_RATE=3
VITE_COINS_PER_TAP=1
VITE_ENERGY_PER_TAP=1
